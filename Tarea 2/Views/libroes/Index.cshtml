@model IEnumerable<Tarea_2.Models.libro>

@{
    ViewData["Title"] = "Index";
}

<h1>Libros</h1>

<p>
    <a class="btn-outline-primary btn" asp-action="Create">Insertar nuevo libro</a>
</p>
<table class="table table-striped table-bordered table-hover">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Titulo)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Autor)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Genero)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Disponibilidad)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Titulo)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Autor)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Genero)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Disponibilidad)
            </td>
            <td>
                <a class="btn-outline-success btn" asp-action="Edit" asp-route-id="@item.Id">Editar</a> |
                <a class="btn-outline-info btn" asp-action="Details" asp-route-id="@item.Id">Detalles</a> |
                <a class="btn-outline-danger btn"  asp-action="Delete" asp-route-id="@item.Id">Eliminar</a>
            </td>
        </tr>
}
    </tbody>
</table>
